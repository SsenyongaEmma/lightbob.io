{
  "expo": {
    "name": "lightBob",
    "slug": "lightBob",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/light_bob_icon.png",
    "color": "#0f1111",
    "scheme": "lightbob",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/light_bob_icon.png",
      "color": "#0f1111"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [],
      "adaptiveIcon": {
        "backgroundColor": "#0f1111",
        "foregroundImage": "./assets/images/light_bob_icon.png",
        "backgroundImage": "./assets/images/light_bob_icon.png",
        "monochromeImage": "./assets/images/light_bob_icon.png"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.emmadante.lightbob"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/light_bob_icon.png"
    },
    "plugins": [

       [
        "expo-notifications",
        {
          "icon": "./assets/images/light_bob_icon.png",
          "color": "#123111",
          "defaultChannel": "default",
          "enableBackgroundNotification": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "useFrameworks": "static",
            "versionCode": 1,
            "manifest": {
            "permissions": {
              "android.permission.ACTIVITY_RECOGNITION": false
            }
          }
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/light_bob_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f1111",
          "dark": {
            "backgroundColor": "#111111"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1195350826022925~8313119802",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ce958b8b-a577-4347-8ed3-b10374dd663a"
      }
    },
    "owner": "emmadantes-organization"
  }
}
